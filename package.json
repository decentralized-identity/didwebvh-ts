{
  "name": "didwebvh-ts",
  "module": "dist/esm/index.js",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/decentralized-identity/didwebvh-ts.git"
  },
  "react-native": "dist/cjs/index.cjs",
  "main": "dist/cjs/index.cjs",
  "browser": "dist/browser/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "tsx --watch ./examples/elysia-resolver.ts",
    "debug": "tsx --watch --inspect ./examples/elysia-resolver.ts",
    "server": "tsx --watch ./examples/elysia-resolver.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "test": "NODE_ENV=test rm -rf ./test/logs/** && vitest run",
    "test:coverage": "NODE_ENV=test rm -rf ./coverage && vitest run --coverage",
    "test:watch": "NODE_ENV=test vitest",
    "test:bail": "NODE_ENV=test vitest run --bail 1 --reporter verbose",
    "test:log": "mkdir -p ./test/logs && LOG_RESOLVES=true NODE_ENV=test vitest run &> ./test/logs/test-run.txt",
    "cli": "tsx src/cli/index.ts",
    "build": "tsx scripts/build.ts",
    "build:clean": "rm -rf dist",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "example:signer": "tsx examples/signer.ts",
    "example:resolver": "tsx examples/elysia-resolver.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@vitest/coverage-v8": "^4.1.10",
    "@stablelib/ed25519": "^2.1.0",
    "@types/node": "^24.13.3",
    "esbuild": "^0.28.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "cookie": "^1.1.1",
    "did-resolver": "^5.0.1",
    "glob": "^13.0.6",
    "js-yaml": "^5.2.1",
    "json-canonicalize": "^2.0.0"
  },
  "bin": {
    "didwebvh": "./dist/cli/didwebvh.js"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "react-native": "./dist/cjs/index.cjs",
      "browser": "./dist/browser/index.js",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./types": {
      "types": "./dist/types/types.d.ts"
    }
  }
}
